{
  "name": "ogstamp",
  "version": "0.1.0",
  "description": "OG image generation API — fast, cached, hosted on Cloudflare Workers",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:local": "wrangler d1 migrations apply ogstamp-db --local",
    "db:remote": "wrangler d1 migrations apply ogstamp-db",
    "test": "node --test \"action/test/*.test.js\""
  },
  "dependencies": {
    "hono": "^4.6.0",
    "workers-og": "^0.0.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260721.1",
    "typescript": "^5.7.3",
    "wrangler": "^4.112.0"
  }
}
