{
  "name": "snapog",
  "version": "0.1.0",
  "description": "OG image generation API — fast, cached, hosted on Cloudflare Workers",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:local": "wrangler d1 migrations apply snapog-db --local",
    "db:remote": "wrangler d1 migrations apply snapog-db",
    "staging:deploy": "wrangler deploy --env staging"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "workers-og": "^0.0.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.7.3",
    "wrangler": "^3.99.0"
  }
}
